# sdrtrunk-pg configuration
# Copy to .env and edit — never commit .env to git

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sdrtrunk

# Filesystem paths for archived call audio and merged files
ARCHIVE_ROOT=/var/sdrtrunk/archive
MERGE_ROOT=/var/sdrtrunk/merges

# API key — must match the key configured in SDRTrunk's Broadcastify Calls plugin
API_KEY=changeme

# Whisper model: tiny | base | small | medium | large
# 'base' is a good balance of speed and accuracy for scanner audio
WHISPER_MODEL=base

# OpenAI — for embeddings and entity extraction (optional; workers skip if unset)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# Alert webhook URL — POST alerts here (e.g. an OpenClaw or Slack webhook)
# Leave blank to disable outbound alerts
ALERT_WEBHOOK_URL=

# Nominatim geocoding
NOMINATIM_URL=https://nominatim.openstreetmap.org
# Bounding box for Hampton Roads geocoding bias: sw_lon,sw_lat,ne_lon,ne_lat
NOMINATIM_VIEWBOX=-76.5,36.5,-75.9,37.2

# Timezone for display (pytz-compatible)
TIMEZONE=America/New_York

# Flask settings
DEBUG=false
PORT=5010
